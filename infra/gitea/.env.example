# infra/gitea/.env  — kopieren nach infra/gitea/.env  (NIE committen; ist gitignored)
# Nur relevant fuer den Umzug auf self-hosted Gitea (docs/migration-to-gitea.md).

# Oeffentliche URL der Gitea-Instanz (bei SSH-Tunnel: http://localhost:3000/)
GITEA_ROOT_URL=http://localhost:3000/

# Fuer den act_runner: interne Erreichbarkeit der Gitea-Instanz
GITEA_INSTANCE_URL=http://gitea:3000

# Runner-Registration-Token (Gitea -> Settings -> Actions -> Runners -> "Create new runner")
RUNNER_TOKEN=<REGISTRATION_TOKEN>
